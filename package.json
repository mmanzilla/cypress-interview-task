{
  "scripts": {
    "test": "cypress run",
    "merge:reports": "mochawesome-merge cypress/reports/individual/*.json > cypress/reports/final.json",
    "generate:report": "marge cypress/reports/final.json --reportDir cypress/reports --inline",
    "report": "npm run test && npm run merge:reports && npm run generate:report"
  },
  "devDependencies": {
    "cypress": "^13.0.0",
    "mochawesome": "^7.1.3",
    "mochawesome-merge": "^4.3.0",
    "mochawesome-report-generator": "^6.2.0"
  }
}
