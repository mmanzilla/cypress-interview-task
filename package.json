{
  "name": "cypress-interview-task",
  "version": "1.0.0",
  "scripts": {
    "clean:reports": "rm -rf cypress/reports",
    "cy:run": "cypress install && cypress run",
    "merge:reports": "npx mochawesome-merge cypress/reports/individual/*.json > cypress/reports/final.json",
    "generate:report": "npx marge cypress/reports/final.json --reportDir cypress/reports --inline",
    "report": "npm run clean:reports && npm run cy:run && npm run merge:reports && npm run generate:report"
  },
  "devDependencies": {
    "cypress": "^13.17.0",
    "mochawesome": "^7.1.3",
    "mochawesome-merge": "^4.3.0",
    "mochawesome-report-generator": "^6.2.0"
  }
}
